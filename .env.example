# 环境变量配置示例
# 复制此文件为 .env 并填入您的配置

# TTS API 配置
# 获取方式：https://xiaomimimo.com
TTS_API_URL=https://token-plan-cn.xiaomimimo.com/v1
TTS_API_KEY=your_api_key_here
TTS_MODEL=mimo-v2.5-tts

# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入您的 API Key
# 3. 运行时使用环境变量：
#    flutter run --dart-define=TTS_API_KEY=your_key

# 或者在构建时设置：
# flutter build apk --dart-define=TTS_API_KEY=your_key
